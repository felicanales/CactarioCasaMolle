{
    "name": "cactario-casa-molle",
    "version": "1.0.0",
    "description": "Sistema de gestión de cactáceas - Casa Molle",
    "private": true,
    "scripts": {
        "build": "npm run build:wms",
        "build:wms": "cd wms && npm install && npm run build",
        "build:app-qr": "cd app-qr && npm install && npm run build",
        "dev": "npm run dev:wms",
        "dev:wms": "cd wms && npm run dev -- -p 3001",
        "dev:app-qr": "cd app-qr && npm run dev",
        "start": "npm run start:all",
        "start:all": "concurrently \"npm run start:backend\" \"npm run start:wms\"",
        "start:all:app-qr": "concurrently \"npm run start:backend\" \"npm run start:wms\" \"npm run start:app-qr\"",
        "start:wms": "cd wms && npm run start:dev -- -p 3001",
        "start:app-qr": "cd app-qr && npm run start",
        "start:backend": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",
        "install:wms": "cd wms && npm install",
        "install:app-qr": "cd app-qr && npm install",
        "install:backend": "cd backend && pip install -r requirements.txt",
        "install:all": "npm run install:wms && npm run install:app-qr && npm run install:backend"
    },
    "engines": {
        "node": ">=22.13.0",
        "python": ">=3.9.0"
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "critters": "^0.0.25"
    }
}
